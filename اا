def get_ai_response(user_message, user_name=None, history=None):
    try:
        # بناء المحادثة بشكل خفيف وحسابي دقيق عشان ما يخلص الرصيد
        messages_list = [{"role": "system", "content": SYSTEM_PROMPT}]
        
        # نأخذ آخر رسالتين بس من الذاكرة عشان ما يثقل الكود
        if history and len(history) > 0:
            for past_msg in history[-2:]:
                messages_list.append({"role": "user", "content": past_msg})
        
        # إضافة الرسالة الحالية
        messages_list.append({"role": "user", "content": user_message})

        response = ai_client.chat.completions.create(
            model="google/gemini-2.5-flash",
            messages=messages_list,
            temperature=0.7,
            max_tokens=150  # 💡 هذا السطر السحري اللي راح يخليه يشتغل بـأقل تكلفة توكنز ومستحيل يضرب 402
        )
        return response.choices[0].message.content
    except Exception as e:
        print(f"Error getting AI response: {e}")
        return "ثواني عيني ثواني، الكود انضرب عندي.. لا تلح الحين لحد ما أعدله!"
